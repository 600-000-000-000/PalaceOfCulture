{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://600.wtf/schemas/signup_profile.schema.json",
  "title": "600B Signup Profile",
  "type": "object",
  "required": ["display_name", "description", "consent"],
  "additionalProperties": false,
  "properties": {
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "vibe": {
      "type": "string",
      "maxLength": 280
    },
    "preferred_aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      },
      "maxItems": 8,
      "uniqueItems": true
    },
    "nostr": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nip05": {
          "type": "string",
          "maxLength": 128
        },
        "pubkey_ref": {
          "type": "string",
          "maxLength": 128
        },
        "create_new": {
          "type": "boolean"
        }
      }
    },
    "lightning": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lightning_address": {
          "type": "string",
          "maxLength": 128
        },
        "lnbits_wallet_ref": {
          "type": "string",
          "maxLength": 128
        },
        "create_lnbits_wallet": {
          "type": "boolean"
        }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "handle": {
          "type": "string",
          "maxLength": 64
        }
      }
    },
    "avatar_preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hair": {
          "type": "string",
          "maxLength": 128
        },
        "outfit": {
          "type": "string",
          "maxLength": 128
        },
        "palette": {
          "type": "string",
          "maxLength": 128
        },
        "companion": {
          "type": "string",
          "maxLength": 128
        },
        "avoid": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 128
          },
          "maxItems": 20
        }
      }
    },
    "consent": {
      "type": "object",
      "required": ["public_profile", "generated_avatar"],
      "additionalProperties": false,
      "properties": {
        "public_profile": {
          "type": "boolean"
        },
        "generated_avatar": {
          "type": "boolean"
        },
        "nostr_anchor": {
          "type": "boolean"
        },
        "lightning_anchor": {
          "type": "boolean"
        }
      }
    }
  }
}
