{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://600.wtf/schemas/member_registry.schema.json",
  "title": "600B Member Registry",
  "type": "object",
  "required": ["version", "privacy_policy", "identity_clusters"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string"
    },
    "privacy_policy": {
      "type": "object",
      "required": ["routing_files_are_source", "forbidden_public_fields"],
      "additionalProperties": true,
      "properties": {
        "routing_files_are_source": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_public_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "identity_clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "display_name",
          "status",
          "public_role",
          "aliases",
          "personas",
          "image_profile",
          "story_profile"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_.-]+$"
          },
          "display_name": {
            "type": "string"
          },
          "status": {
            "enum": ["canon", "candidate", "archived"]
          },
          "website": {
            "type": "object",
            "additionalProperties": true
          },
          "public_role": {
            "type": "string"
          },
          "legacy_role": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "personas": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "kind", "use_when", "prompt_cues", "avoid_drift"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                },
                "use_when": {
                  "type": "string"
                },
                "prompt_cues": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "avoid_drift": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "nostr_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "value"],
              "properties": {
                "type": {
                  "enum": ["nip05", "pubkey_ref", "pending"]
                },
                "value": {
                  "type": "string"
                },
                "routing_source": {
                  "type": "string"
                }
              }
            }
          },
          "lightning_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "value"],
              "properties": {
                "type": {
                  "enum": ["lnurlp", "lightning_address", "lnbits_ref", "pending"]
                },
                "value": {
                  "type": "string"
                },
                "routing_source": {
                  "type": "string"
                }
              }
            }
          },
          "github_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["handle"],
              "properties": {
                "handle": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                }
              }
            }
          },
          "image_profile": {
            "type": "object",
            "required": ["source_image", "avatar_description", "silhouette", "key_objects", "avoid_drift"],
            "additionalProperties": false,
            "properties": {
              "source_image": {
                "type": "string"
              },
              "avatar_description": {
                "type": "string"
              },
              "silhouette": {
                "type": "string"
              },
              "key_objects": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "avoid_drift": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "story_profile": {
            "type": "object",
            "required": ["function", "rpg_role", "scene_samples"],
            "additionalProperties": false,
            "properties": {
              "function": {
                "type": "string"
              },
              "rpg_role": {
                "type": "string"
              },
              "scene_samples": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
